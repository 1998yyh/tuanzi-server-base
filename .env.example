# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=tuanzi_server

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production

# CORS 配置（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# JWT 过期时间（秒）：access token 默认 7200（2 小时），refresh token 默认 604800（7 天）
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800
